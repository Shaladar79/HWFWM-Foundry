<section class="hwfwm-actor-sheet">

  <header class="sheet-header">
    <img
      class="profile-img"
      src="{{actor.img}}"
      data-edit="img"
      alt="{{actor.name}}"
      title="{{actor.name}}"
      width="100"
      height="100"
    />

    <div class="header-fields">
      <h1 class="actor-name">
        <input
          type="text"
          name="name"
          value="{{actor.name}}"
          placeholder="Name"
          {{disabled (not editable)}}
        />
      </h1>

      <div class="actor-type">
        <strong>Actor Type:</strong>
        <span>{{actorType}}</span>
      </div>
    </div>
  </header>

  <section class="resources">

    <div class="resource">
      <label>Life Force</label>

      <div class="resource-values">
        <input
          type="number"
          name="system.lifeForce.value"
          value="{{system.lifeForce.value}}"
          min="0"
          {{disabled (not editable)}}
        />

        <span>/</span>

        <input
          type="number"
          name="system.lifeForce.max"
          value="{{system.lifeForce.max}}"
          min="0"
          {{disabled (not editable)}}
        />
      </div>
    </div>

    <div class="resource">
      <label>Mana</label>

      <div class="resource-values">
        <input
          type="number"
          name="system.mana.value"
          value="{{system.mana.value}}"
          min="0"
          {{disabled (not editable)}}
        />

        <span>/</span>

        <input
          type="number"
          name="system.mana.max"
          value="{{system.mana.max}}"
          min="0"
          {{disabled (not editable)}}
        />
      </div>
    </div>

    <div class="resource">
      <label>Stamina</label>

      <div class="resource-values">
        <input
          type="number"
          name="system.stamina.value"
          value="{{system.stamina.value}}"
          min="0"
          {{disabled (not editable)}}
        />

        <span>/</span>

        <input
          type="number"
          name="system.stamina.max"
          value="{{system.stamina.max}}"
          min="0"
          {{disabled (not editable)}}
        />
      </div>
    </div>

  </section>

  <nav class="sheet-tabs" data-group="primary">
    <button
      type="button"
      class="tab"
      data-action="tab"
      data-group="primary"
      data-tab="description"
    >
      Description
    </button>

    <button
      type="button"
      class="tab"
      data-action="tab"
      data-group="primary"
      data-tab="abilities"
    >
      Abilities
    </button>

    <button
      type="button"
      class="tab"
      data-action="tab"
      data-group="primary"
      data-tab="essences"
    >
      Essences
    </button>

    <button
      type="button"
      class="tab"
      data-action="tab"
      data-group="primary"
      data-tab="inventory"
    >
      Inventory
    </button>
  </nav>

  <section class="sheet-body">

    <section
      class="tab"
      data-group="primary"
      data-tab="description"
    >
      <div class="form-group stacked">
        <label for="{{rootId}}-description">Description</label>

        <textarea
          id="{{rootId}}-description"
          name="system.description"
          rows="14"
          placeholder="Enter a description..."
          {{disabled (not editable)}}
        >{{system.description}}</textarea>
      </div>
    </section>

    <section
      class="tab"
      data-group="primary"
      data-tab="abilities"
    >
      <header class="items-header">
        <h2>Abilities</h2>
      </header>

      <ol class="items-list">
        {{#each abilities as |item|}}
          <li class="item" data-item-id="{{item.id}}">
            <img
              class="item-image"
              src="{{item.img}}"
              alt="{{item.name}}"
              title="{{item.name}}"
              width="32"
              height="32"
            />

            <span class="item-name">{{item.name}}</span>

            <span class="item-detail">
              Action Cost: {{item.system.actionCost}}
            </span>
          </li>
        {{else}}
          <li class="item-empty">No abilities added.</li>
        {{/each}}
      </ol>
    </section>

    <section
      class="tab"
      data-group="primary"
      data-tab="essences"
    >
      <header class="items-header">
        <h2>Essences</h2>
      </header>

      <ol class="items-list">
        {{#each essences as |item|}}
          <li class="item" data-item-id="{{item.id}}">
            <img
              class="item-image"
              src="{{item.img}}"
              alt="{{item.name}}"
              title="{{item.name}}"
              width="32"
              height="32"
            />

            <span class="item-name">{{item.name}}</span>

            {{#if item.system.isConfluence}}
              <span class="item-detail">Confluence</span>
            {{else}}
              <span class="item-detail">Essence</span>
            {{/if}}
          </li>
        {{else}}
          <li class="item-empty">No essences added.</li>
        {{/each}}
      </ol>
    </section>

    <section
      class="tab"
      data-group="primary"
      data-tab="inventory"
    >
      <header class="items-header">
        <h2>Equipment</h2>
      </header>

      <ol class="items-list">
        {{#each equipment as |item|}}
          <li class="item" data-item-id="{{item.id}}">
            <img
              class="item-image"
              src="{{item.img}}"
              alt="{{item.name}}"
              title="{{item.name}}"
              width="32"
              height="32"
            />

            <span class="item-name">{{item.name}}</span>

            <span class="item-detail">
              Quantity: {{item.system.quantity}}
            </span>
          </li>
        {{else}}
          <li class="item-empty">No equipment added.</li>
        {{/each}}
      </ol>

      <header class="items-header">
        <h2>Consumables</h2>
      </header>

      <ol class="items-list">
        {{#each consumables as |item|}}
          <li class="item" data-item-id="{{item.id}}">
            <img
              class="item-image"
              src="{{item.img}}"
              alt="{{item.name}}"
              title="{{item.name}}"
              width="32"
              height="32"
            />

            <span class="item-name">{{item.name}}</span>

            <span class="item-detail">
              Quantity: {{item.system.quantity}}
            </span>
          </li>
        {{else}}
          <li class="item-empty">No consumables added.</li>
        {{/each}}
      </ol>
    </section>

  </section>

</section>
